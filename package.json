  "scripts": {
    "start:demo-ngrx-classic": "nx serve demo-ngrx-classic",
    "start:demo-ngrx-classic:for-tests": "nx serve demo-ngrx-classic --configuration=e2e-tests",
    "start:demo-ngrx-classic:e2e": "nx e2e demo-ngrx-classic",
    "start:prod:demo-ngrx-classic": "nx serve demo-ngrx-classic --configuration=production",
    "start:demo-ngrx-signals": "nx serve demo-ngrx-signals",
    "start:demo-ngrx-signals:for-tests": "nx serve demo-ngrx-signals --configuration=e2e-tests",
    "start:demo-ngrx-signals:e2e": "nx e2e demo-ngrx-signals",
    "start:prod:demo-ngrx-signal": "nx serve demo-ngrx-signals --configuration=production",
    "start:server": "nx serve server",
    "start:documentation": "nx serve documentation --configuration=serve --port=4202",
    "build:documentation": "pnpm nx run documentation:build:production",
    "git-publish": "node tools/scripts/publish.js",
    "build-lint": "exec nx affected -t build lint --exclude=documentation --parallel=5",
    "build": "nx affected:build --exclude=documentation --parallel=5",
    "lint": "nx affected:lint --parallel=5",
    "lint:fix": "nx affected:lint --parallel=5 --fix",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "test": "nx affected:test --parallel=5 --max-parallel=5",
    "test:coverage": "pnpm test -- --coverage",
    "dupcheck": "pnpm jscpd",
    "htmllint": "pnpm htmlhint \"apps/**/*.html\" \"libs/**/*.html\" --ignore=\"coverage/**/*\"",
    "prepare": "is-ci || husky",
    "postinstall": "pnpm prisma generate && (is-ci || pnpm prisma migrate dev)",
    "reset": "rm -rf dist && rm -rf node_modules && rm -rf .angular && rm -rf .nx && pnpm install"
  },
  "prisma": {
    "seed": "pnpm ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "lint-staged": {
    "*.{js,ts,css,scss,md,json,html}": [
      "pnpm format"
    ],
    "*.{js,ts,html}": [
      "pnpm lint"
    ],
    "*.html": [
      "pnpm htmllint"
    ]
  },
